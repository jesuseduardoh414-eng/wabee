# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Connection pooling (para Prisma en producción)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection (para migraciones)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Forzar motor de librería (evita error engine type "client")
PRISMA_CLIENT_ENGINE_TYPE=library
PRISMA_CLI_QUERY_ENGINE_TYPE=library

# ─── Runtime ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS / URLs ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:4000

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_64_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SMTP (cPanel — red4design.com) ──────────────────────────────────────────
# Servidor: red4design.com (hostname real del hosting cPanel)
# Cuenta creada en cPanel: noreply@wabee.website
SMTP_HOST=red4design.com
SMTP_PORT=587
SMTP_USER=noreply@wabee.website
SMTP_PASS=your-cpanel-email-password
SMTP_FROM=noreply@wabee.website

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_REDIRECT_URI="http://localhost:4000/oauth/meta/callback"
META_GRAPH_VERSION="v25.0"
# Embedded Signup: configuration_id de "Facebook Login for Business" (para Coexistence)
META_CONFIG_ID="your-embedded-signup-config-id"

# Variables canónicas (producción)
WHATSAPP_ACCESS_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-verify-token"

# ─── Encryption & Security ───────────────────────────────────────────────────
# TOKEN_ENC_KEY debe ser un string hex de 64 caracteres (32 bytes)
TOKEN_ENC_KEY="your-64-char-hex-string"
BOOTSTRAP_SECRET="your-bootstrap-secret"

# ─── AWS (requerido por algunas dependencias, puede ser dummy en dev) ─────────
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_REGION=us-east-1

# ─── AI ──────────────────────────────────────────────────────────────────────
ENABLE_AI_WIDGET=true
AI_WIDGET_ALWAYS_RESPOND=true
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ─── Redis ───────────────────────────────────────────────────────────────────
# false en dev local, true en producción con Redis real (Upstash)
REDIS_ENABLED=false
# REDIS_URL=redis://...
