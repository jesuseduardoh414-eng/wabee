{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "tsx watch src/index.ts",
    "build": "npx rimraf dist && tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "wipe:dev": "cross-env WIPE_DEV_DATA=true tsx scripts/wipe-dev-data.ts",
    "sync:stripe": "tsx src/scripts/sync-stripe-plans.ts",
    "sync:stripe:force": "tsx src/scripts/clear-stripe-ids.ts && tsx src/scripts/sync-stripe-plans.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.4.2",
    "@r4d-26/core": "5.18.0",
    "@supabase/supabase-js": "^2.97.0",
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "otplib": "^13.3.0",
    "pdf-parse": "1.1.1",
    "pg": "^8.21.0",
    "pg-connection-string": "^2.6.2",
    "qrcode": "^1.5.4",
    "stripe": "^17.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.41",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/qs": "^6.9.11",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.1",
    "prisma": "7.4.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
