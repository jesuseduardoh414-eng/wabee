generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
  binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["wabee"]
}

model UserProfile {
  id        String   @id @default(cuid())
  tenantId  String
  name      String?
  createdAt DateTime @default(now())

  @@schema("wabee")
}

model AuthChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  type       String    @default("LOGIN_2FA")
  status     String    @default("PENDING")
  metadata   Json?     @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("auth_challenges")
  @@schema("wabee")
}

model MetaOauthSession {
  id                    String            @id @default(uuid()) @db.Uuid
  tenantId              String            @map("organization_id") @db.Uuid
  provider              String            @default("META")
  accessTokenCiphertext String            @map("access_token_ciphertext")
  accessTokenIv         String            @map("access_token_iv")
  accessTokenTag        String            @map("access_token_tag")
  tokenExpiresAt        DateTime?         @map("token_expires_at") @db.Timestamptz(6)
  scopes                String[]          @default([])
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  whatsappChannels      WhatsappChannel[]

  @@index([tenantId])
  @@map("meta_oauth_sessions")
  @@schema("wabee")
}

model WhatsappChannel {
  id                      String                  @id @default(uuid()) @db.Uuid
  tenantId                String                  @map("organization_id") @db.Uuid
  name                    String
  purpose                 String                  @default("GENERAL")
  status                  String                  @default("CONNECTED")
  wabaId                  String                  @map("waba_id")
  phoneNumberId           String                  @map("phone_number_id")
  metaAppId               String?                 @map("meta_app_id")
  displayPhone            String?                 @map("display_phone")
  verifiedName            String?                 @map("verified_name")
  webhookStatus           String                  @default("PENDING") @map("webhook_status")
  healthStatus            String                  @default("UNKNOWN") @map("health_status")
  healthFailureCount      Int                     @default(0) @map("health_failure_count")
  lastHealthyAt           DateTime?               @map("last_healthy_at") @db.Timestamptz(6)
  lastHealthCheckAt       DateTime?               @map("last_health_check_at") @db.Timestamptz(6)
  lastErrorCode           String?                 @map("last_error_code")
  lastErrorMessage        String?                 @map("last_error_message")
  lastErrorAt             DateTime?               @map("last_error_at") @db.Timestamptz(6)
  oauthSessionId          String?                 @map("oauth_session_id") @db.Uuid
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt              DateTime?               @map("archived_at") @db.Timestamptz(6)
  aiEnabled               Boolean                 @default(false) @map("ai_enabled")
  defaultAiProfileId      String?                 @map("default_ai_profile_id") @db.Uuid
  humanHandoffEnabled     Boolean                 @default(true) @map("human_handoff_enabled")
  humanHandoffRole        HumanHandoffRole?       @map("human_handoff_role")
  /// Metadata informativa (no routing autoritativo). No usar como FK.
  humanTeamRef            String?                 @map("human_team_ref") @db.VarChar(120)
  fallbackMessage         String?                 @map("fallback_message")
  aiMode                  ChannelAiMode           @default(disabled) @map("ai_mode")
  whatsappAgentBinding    WhatsappAgentBinding?
  whatsappCampaigns       WhatsappCampaign[]
  defaultAiProfile        AiProfile?              @relation("ChannelDefaultAiProfile", fields: [defaultAiProfileId], references: [id])
  oauthSession            MetaOauthSession?       @relation(fields: [oauthSessionId], references: [id])
  whatsappMessageStatuses WhatsappMessageStatus[]
  whatsappMessages        WhatsappMessage[]
  whatsappTemplates       WhatsappTemplate[]
  whatsappThreads         WhatsappThread[]

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId])
  @@index([tenantId, aiEnabled])
  @@map("whatsapp_channels")
  @@schema("wabee")
}

model WhatsappMessage {
  id               String                    @id @default(uuid()) @db.Uuid
  tenantId         String                    @map("organization_id") @db.Uuid
  channelId        String                    @map("channel_id") @db.Uuid
  direction        String
  threadId         String?                   @map("thread_id") @db.Uuid
  waMessageId      String?                   @map("wa_message_id")
  fromPhone        String                    @map("from_phone")
  toPhone          String                    @map("to_phone")
  remotePhone      String                    @map("remote_phone")
  type             String
  textBody         String?                   @map("text_body")
  timestamp        DateTime                  @db.Timestamptz(6)
  status           String                    @default("RECEIVED")
  deliveryStatus   String?                   @map("delivery_status")
  errorCode        String?                   @map("error_code")
  errorMessage     String?                   @map("error_message")
  deliveredAt      DateTime?                 @map("delivered_at") @db.Timestamptz(6)
  readAt           DateTime?                 @map("read_at") @db.Timestamptz(6)
  rawPayload       Json?                     @map("raw_payload")
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  metadata         Json?
  source           String?
  externalRef      String?                   @map("external_ref")
  senderType       MessageSenderType?        @map("sender_type")
  senderUserId     String?                   @map("sender_user_id") @db.Uuid
  aiProfileId      String?                   @map("ai_profile_id") @db.Uuid
  generatedBy      MessageGeneratedBy?       @map("generated_by")
  campaignMessages WhatsappCampaignMessage[]
  aiProfile        AiProfile?                @relation("MessageAiProfile", fields: [aiProfileId], references: [id])
  channel          WhatsappChannel           @relation(fields: [channelId], references: [id])
  thread           WhatsappThread?           @relation(fields: [threadId], references: [id])

  @@unique([tenantId, externalRef], map: "uq_whatsapp_messages_org_external_ref", where: raw("(external_ref IS NOT NULL)"))
  @@index([tenantId])
  @@index([channelId])
  @@index([threadId])
  @@index([tenantId, channelId])
  @@index([remotePhone])
  @@index([timestamp])
  @@index([tenantId, externalRef], map: "idx_whatsapp_messages_tenant_external_ref")
  @@index([threadId, senderType, direction])
  @@index([tenantId, waMessageId], map: "idx_whatsapp_messages_org_wa_message_id", where: raw("(wa_message_id IS NOT NULL)"))
  @@map("whatsapp_messages")
  @@schema("wabee")
}

model WhatsappThread {
  id                   String               @id @default(uuid()) @db.Uuid
  tenantId             String               @map("organization_id") @db.Uuid
  channelId            String               @map("channel_id") @db.Uuid
  contactPhone         String               @map("contact_phone")
  contactName          String?              @map("contact_name")
  lastMessageAt        DateTime             @default(now()) @map("last_message_at") @db.Timestamptz(6)
  lastMessagePreview   String?              @map("last_message_preview")
  unreadCount          Int                  @default(0) @map("unread_count")
  status               String               @default("OPEN")
  metadata             Json?
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  contactId            String?              @map("contact_id") @db.Uuid
  assignedUserId       String?              @map("assigned_user_id") @db.Uuid
  contextState         Json?                @map("context_state")
  currentFlowVersionId String?              @map("current_flow_version_id") @db.Uuid
  automationState      Json?                @map("automation_state")
  source               String?
  /// NULL intencionalmente: ThreadStateOrchestrator.openThread() asigna el valor correcto.
  handlingMode         ThreadHandlingMode?  @map("handling_mode")
  assignedAiProfileId  String?              @map("assigned_ai_profile_id") @db.Uuid
  aiPaused             Boolean              @default(false) @map("ai_paused")
  aiPausedAt           DateTime?            @map("ai_paused_at") @db.Timestamptz(6)
  aiPausedByUserId     String?              @map("ai_paused_by_user_id") @db.Uuid
  takeoverReason       String?              @map("takeover_reason") @db.VarChar(120)
  humanTakeoverAt      DateTime?            @map("human_takeover_at") @db.Timestamptz(6)
  humanTakeoverBy      String?              @map("human_takeover_by") @db.Uuid
  lastResponderType    MessageSenderType?   @map("last_responder_type")
  notes                ThreadNote[]
  messages             WhatsappMessage[]
  whatsappNotes        WhatsappThreadNote[]
  assignedAiProfile    AiProfile?              @relation("ThreadAssignedAiProfile", fields: [assignedAiProfileId], references: [id])
  channel              WhatsappChannel         @relation(fields: [channelId], references: [id])
  contact              Contact?                @relation(fields: [contactId], references: [id])
  currentFlowVersion   AutomationFlowVersion?  @relation(fields: [currentFlowVersionId], references: [id])

  @@unique([tenantId, channelId, contactPhone])
  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([channelId])
  @@index([lastMessageAt])
  @@index([tenantId, handlingMode])
  @@index([tenantId, aiPaused])
  @@map("whatsapp_threads")
  @@schema("wabee")
}

model WhatsappThreadNote {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  threadId    String         @db.Uuid
  body        String
  isPinned    Boolean        @default(false)
  createdById String?        @db.Uuid
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)
  thread      WhatsappThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, threadId, isPinned])
  @@map("whatsapp_thread_notes")
  @@schema("wabee")
}

model Contact {
  id                String                    @id @default(uuid()) @db.Uuid
  tenantId          String                    @map("organization_id") @db.Uuid
  phone             String
  name              String?
  email             String?
  lastInteractionAt DateTime?                 @map("last_interaction_at") @db.Timestamptz(6)
  status            ContactStatus             @default(ACTIVE)
  lifecycleStatus   ContactLifecycleStatus    @default(NEW) @map("lifecycle_status")
  externalCrmId     String?                   @map("external_crm_id")
  sourceSystem      String?                   @map("source_system")
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  tags              Json                      @default("[]")
  contactGroups     ContactGroup[]
  lifecycleEvents   ContactLifecycleEvent[]
  campaignMessages  WhatsappCampaignMessage[]
  whatsappThreads   WhatsappThread[]

  @@unique([tenantId, phone])
  @@index([tenantId, phone])
  @@index([tenantId, lifecycleStatus])
  @@index([tenantId, status])
  @@map("contacts")
  @@schema("wabee")
}

model Group {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("organization_id") @db.Uuid
  name          String
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  contactGroups ContactGroup[]

  @@unique([tenantId, name])
  @@index([tenantId, name])
  @@map("groups")
  @@schema("wabee")
}

model ContactGroup {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("organization_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactId, groupId])
  @@index([tenantId, groupId])
  @@index([tenantId, contactId])
  @@map("contact_groups")
  @@schema("wabee")
}

model SavedSegment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("organization_id") @db.Uuid
  name        String
  description String?
  filter      Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("saved_segments")
  @@schema("wabee")
}

model ContactLifecycleEvent {
  id          String                 @id @default(uuid()) @db.Uuid
  tenantId    String                 @map("organization_id") @db.Uuid
  contactId   String                 @map("contact_id") @db.Uuid
  fromStatus  ContactLifecycleStatus @map("from_status")
  toStatus    ContactLifecycleStatus @map("to_status")
  actorUserId String?                @map("actor_user_id") @db.Uuid
  source      String
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  contact     Contact                @relation(fields: [contactId], references: [id])

  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
  @@map("contact_lifecycle_events")
  @@schema("wabee")
}

model WhatsappMessageStatus {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @map("organization_id") @db.Uuid
  messageId  String          @map("message_id") @db.Uuid
  channelId  String          @map("channel_id") @db.Uuid
  status     String
  timestamp  DateTime        @db.Timestamptz(6)
  rawPayload Json?           @map("raw_payload")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  channel    WhatsappChannel @relation(fields: [channelId], references: [id])

  @@index([tenantId])
  @@index([messageId])
  @@index([timestamp])
  @@map("whatsapp_message_statuses")
  @@schema("wabee")
}

model ThreadNote {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("organization_id") @db.Uuid
  threadId     String         @map("thread_id") @db.Uuid
  authorUserId String?        @map("author_user_id") @db.Uuid
  body         String
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  thread       WhatsappThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tenantId, threadId])
  @@map("thread_notes")
  @@schema("wabee")
}

model WhatsappTemplate {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("organization_id") @db.Uuid
  channelId         String             @map("channel_id") @db.Uuid
  name              String
  language          String
  category          String
  status            String
  components        Json
  metaTemplateId    String?            @map("meta_template_id")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  whatsappCampaigns WhatsappCampaign[]
  channel           WhatsappChannel    @relation(fields: [channelId], references: [id])

  @@unique([tenantId, channelId, name, language])
  @@index([tenantId])
  @@index([channelId])
  @@index([tenantId, channelId])
  @@map("whatsapp_templates")
  @@schema("wabee")
}

model WebWidget {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("organization_id") @db.Uuid
  title          String
  subtitle       String?
  welcomeMessage String?     @map("welcome_message")
  domainAllowed  String[]    @default([]) @map("domain_allowed")
  aiEnabled      Boolean     @default(false) @map("ai_enabled")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  features       Json?
  theme          Json?
  content        Json?
  ai             Json?
  threads        WebThread[]

  @@index([tenantId])
  @@map("web_widgets")
  @@schema("wabee")
}

model WebThread {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("organization_id") @db.Uuid
  widgetId         String          @map("widget_id") @db.Uuid
  visitorId        String          @map("visitor_id")
  sessionId        String?         @map("session_id")
  status           WebThreadStatus @default(OPEN)
  contextState     Json?           @map("context_state")
  aiPaused         Boolean         @default(false) @map("ai_paused")
  aiPausedAt       DateTime?       @map("ai_paused_at") @db.Timestamptz(6)
  aiPausedByUserId String?         @map("ai_paused_by_user_id") @db.Uuid
  lastMessageAt    DateTime?       @map("last_message_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages         WebMessage[]
  widget           WebWidget       @relation(fields: [widgetId], references: [id])

  @@index([tenantId])
  @@index([widgetId])
  @@index([tenantId, widgetId, visitorId])
  @@index([tenantId, widgetId, visitorId, status])
  @@map("web_threads")
  @@schema("wabee")
}

model WebMessage {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @map("organization_id") @db.Uuid
  threadId  String              @map("thread_id") @db.Uuid
  direction String
  actorType WebMessageActorType @map("actor_type")
  text      String
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  thread    WebThread           @relation(fields: [threadId], references: [id])

  @@index([tenantId, threadId])
  @@map("web_messages")
  @@schema("wabee")
}

model AiProfile {
  id                    String                 @id @default(uuid()) @db.Uuid
  tenantId              String                 @map("organization_id") @db.Uuid
  name                  String
  tone                  String?
  tones                 String[]               @default([])
  systemPrompt          String                 @map("system_prompt")
  agentName             String?                @map("agent_name")
  roleTitle             String?                @map("role_title")
  personalityNotes      String?                @map("personality_notes")
  examples              Json?
  greetingStyle         GreetingStyle          @default(WARM) @map("greeting_style")
  fallbackMessage       String?                @map("fallback_message")
  fallbackMode          FallbackMode           @default(CUSTOM) @map("fallback_mode")
  fallbackCustomMessage String?                @map("fallback_custom_message")
  maxTokens             Int                    @default(512) @map("max_tokens")
  confidenceThreshold   Float                  @default(0.6) @map("confidence_threshold")
  channelType           AiChannelType          @default(WIDGET) @map("channel_type")
  kbEnabled             Boolean                @default(true) @map("kb_enabled")
  /// Nivel de agresividad del agente ante KB insuficiente: conservative | balanced | aggressive
  /// conservative = handoff rápido (1 reintento KB)
  /// balanced     = reinterpretación + pregunta aclaratoria (default WABEE)
  /// aggressive   = máxima interpretación, 2 reintentos KB + pregunta aclaratoria
  handoffAggressiveness String                 @default("balanced") @map("handoff_aggressiveness") @db.VarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  aiProfileTools        AiProfileTool[]
  kbFiles               KbFile[]
  kbSources             KbSource[]
  whatsappAgentBindings WhatsappAgentBinding[]
  channelsAsDefault     WhatsappChannel[]      @relation("ChannelDefaultAiProfile")
  messagesGenerated     WhatsappMessage[]      @relation("MessageAiProfile")
  threadsAssigned       WhatsappThread[]       @relation("ThreadAssignedAiProfile")

  @@index([tenantId])
  @@map("ai_profiles")
  @@schema("wabee")
}

model KbFile {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("organization_id") @db.Uuid
  profileId   String?    @map("profile_id") @db.Uuid
  filename    String
  mimeType    String     @map("mime_type")
  size        Int
  storagePath String     @map("storage_path")
  status      String     @default("PROCESSING")
  error       String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  chunks      KbChunk[]
  profile     AiProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, profileId])
  @@map("kb_files")
  @@schema("wabee")
}

model KbChunk {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("organization_id") @db.Uuid
  fileId      String?   @map("file_id") @db.Uuid
  sourceId    String?   @map("source_id") @db.Uuid
  profileId   String?   @map("profile_id") @db.Uuid
  idx         Int       @default(0)
  section     String?   @db.VarChar(120)
  content     String
  contentNorm String    @default("") @map("content_norm")
  charStart   Int?      @map("char_start")
  charEnd     Int?      @map("char_end")
  embedding   Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  file        KbFile?   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  source      KbSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fileId])
  @@index([sourceId])
  @@index([tenantId, profileId])
  @@index([tenantId, profileId, fileId])
  @@index([tenantId, profileId, idx])
  @@map("kb_chunks")
  @@schema("wabee")
}

model KbSource {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("organization_id") @db.Uuid
  profileId    String?         @map("profile_id") @db.Uuid
  name         String
  sourceType   KbSourceType    @map("source_type")
  status       KbSourceStatus  @default(PENDING) @map("status")
  config       Json?
  error        String?
  vectorSyncAt DateTime?       @map("vector_sync_at") @db.Timestamptz(6)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  chunks       KbChunk[]
  profile      AiProfile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, profileId])
  @@map("kb_sources")
  @@schema("wabee")
}

model AiAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("organization_id") @db.Uuid
  channel         String
  widgetId        String?  @map("widget_id") @db.Uuid
  threadId        String?  @map("thread_id") @db.Uuid
  effectivePrompt String   @map("effective_prompt")
  provider        String   @default("OLLAMA")
  model           String
  responseText    String?  @map("response_text")
  confidenceScore Float?   @map("confidence_score")
  action          String
  errorMessage    String?  @map("error_message")
  kbFileIds       Json?    @map("kb_file_ids")
  kbChunkIds      Json?    @map("kb_chunk_ids")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([widgetId])
  @@index([threadId])
  @@index([createdAt])
  @@map("ai_audit_logs")
  @@schema("wabee")
}

model WhatsappCampaign {
  id                   String                    @id @default(uuid()) @db.Uuid
  tenantId             String                    @map("organization_id") @db.Uuid
  channelId            String                    @map("channel_id") @db.Uuid
  templateId           String?                   @map("template_id") @db.Uuid
  name                 String
  status               WhatsappCampaignStatus    @default(DRAFT)
