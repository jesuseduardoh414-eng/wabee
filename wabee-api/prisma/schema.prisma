  @@index([tenant_id, target_type])
  @@schema("wabee")
}

model ui_theme_versions {
  id                 String    @id @db.Uuid
  theme_id           String    @db.Uuid
  version_number     Int
  snapshot           Json
  change_summary     String?
  created_by_user_id String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  ui_themes          ui_themes @relation(fields: [theme_id], references: [id], onDelete: Cascade)

  @@unique([theme_id, version_number])
  @@index([theme_id])
  @@schema("wabee")
}

model ui_themes {
  id                   String                 @id @db.Uuid
  tenant_id            String                 @db.Uuid
  name                 String
  description          String?
  scope                String                 @default("tenant")
  status               UiThemeStatus          @default(DRAFT)
  is_active            Boolean                @default(false)
  tokens               Json                   @default("{}")
  presets              Json                   @default("{}")
  created_by_user_id   String?                @db.Uuid
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @db.Timestamptz(6)
  ui_theme_assets      ui_theme_assets[]
  ui_theme_assignments ui_theme_assignments[]
  ui_theme_versions    ui_theme_versions[]
  ui_user_preferences  ui_user_preferences[]

  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, status])
  @@schema("wabee")
}

model ui_user_preferences {
  id                String     @id @db.Uuid
  tenant_id         String     @db.Uuid
  user_id           String     @db.Uuid
  theme_id          String?    @db.Uuid
  density           String     @default("comfortable")
  sidebar_collapsed Boolean    @default(false)
  dashboard_layout  Json?
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime   @db.Timestamptz(6)
  ui_themes         ui_themes? @relation(fields: [theme_id], references: [id])

  @@unique([tenant_id, user_id])
  @@index([tenant_id, user_id])
  @@schema("wabee")
}

