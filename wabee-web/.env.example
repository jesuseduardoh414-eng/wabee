# Variables de entorno del frontend de WABEE
# Copia este archivo como .env.local y rellena los valores

# URL del backend de WABEE
# En desarrollo con proxy Vite dejar comentado (usa /v1 por defecto)
# En producción (Render) poner la URL real: https://wabee-api.onrender.com/v1
# VITE_API_URL=https://wabee-api.onrender.com/v1

# ─── Meta WhatsApp Embedded Signup (Coexistence) ─────────────────────────────
# Se llenan al configurar la Meta App (App ID público + configuration_id del
# flujo "Facebook Login for Business"). Sin estos, el botón de Coexistence
# fallará de forma controlada.
VITE_META_APP_ID=
VITE_META_CONFIG_ID=
VITE_META_GRAPH_VERSION=v19.0

# Credenciales PÚBLICAS de Supabase (solo ANON KEY, NUNCA service_role)
# Las encuentras en: Supabase Dashboard → Settings → API
